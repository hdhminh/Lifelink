{
  "name": "lifelink",
  "private": false,
  "version": "1.0.0",
  "description": "Connected Lives Vietnam - Emergency Blood Donor Coordination Platform",
  "author": "LifeLink Project Authors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/COS30043/LifeLink.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed-users": "node --env-file=.env scripts/seed-users.js",
    "db:seed-events": "node --env-file=.env scripts/seed-events.js",
    "db:seed-requests": "node --env-file=.env scripts/seed-requests.js",
    "db:seed": "npm run db:seed-users && npm run db:seed-events && npm run db:seed-requests"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "motion": "^12.42.2",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "c8": "^12.0.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.10"
  }
}
